{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "app",
    "outDir": "dist",
    "allowJs": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["app/**/*.ts"],
  "exclude": ["dist", "node_modules", "test"]
}
