    "memoizee": "^0.4.14"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/luxon": "^3.7.1",
    "@types/memoizee": "^0.4.12",
    "@types/node": "^25.5.0",
    "nock": "^14.0.11",
    "prettier": "1.14.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
